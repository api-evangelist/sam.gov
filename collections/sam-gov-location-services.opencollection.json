{
  "opencollection": "1.0.0",
  "info": {
    "name": "SAM.gov Public Location Services API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Cities",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get List of Cities",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.sam.gov/locationservices/v1/cities",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "SAM.gov Federal Government System Account API key"
              },
              {
                "name": "cc",
                "value": "",
                "type": "query",
                "description": "Country code (ISO 3166-1 alpha-2, e.g. US for United States)"
              },
              {
                "name": "searchby",
                "value": "",
                "type": "query",
                "description": "Field to search by (e.g. cityname, citycode)"
              },
              {
                "name": "searchvalue",
                "value": "",
                "type": "query",
                "description": "Value to search for"
              },
              {
                "name": "q",
                "value": "",
                "type": "query",
                "description": "General query string for city name search"
              },
              {
                "name": "active",
                "value": "",
                "type": "query",
                "description": "Filter to active cities only (Y/N)"
              },
              {
                "name": "citycode",
                "value": "",
                "type": "query",
                "description": "City code to filter by"
              }
            ]
          },
          "docs": "Retrieve a list of cities for a given country code. Supports searching by city name, active status, and city code filters. Used to validate city data being submitted to SAM.gov."
        }
      ]
    },
    {
      "info": {
        "name": "States",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get List of States and Provinces",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.sam.gov/locationservices/v1/states",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "SAM.gov Federal Government System Account API key"
              },
              {
                "name": "cc",
                "value": "",
                "type": "query",
                "description": "Country code (ISO 3166-1 alpha-2, e.g. US for United States)"
              },
              {
                "name": "searchby",
                "value": "",
                "type": "query",
                "description": "Field to search by (e.g. statename, statecode)"
              },
              {
                "name": "q",
                "value": "",
                "type": "query",
                "description": "General query string for state name search"
              },
              {
                "name": "active",
                "value": "",
                "type": "query",
                "description": "Filter to active states/provinces only (Y/N)"
              }
            ]
          },
          "docs": "Retrieve a list of states, provinces, and subdivisions for both the United States and foreign countries. Supports searching by state/province name or code. Used to validate state data submitted to SAM.gov."
        }
      ]
    },
    {
      "info": {
        "name": "ZIP Codes",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Validate ZIP Code",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.sam.gov/locationservices/v1/zip",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "SAM.gov Federal Government System Account API key"
              },
              {
                "name": "zip",
                "value": "",
                "type": "query",
                "description": "ZIP code to validate (5 digits for US postal codes)"
              },
              {
                "name": "citycode",
                "value": "",
                "type": "query",
                "description": "City code filter"
              },
              {
                "name": "countycode",
                "value": "",
                "type": "query",
                "description": "County code filter"
              },
              {
                "name": "statecode",
                "value": "",
                "type": "query",
                "description": "State code filter"
              }
            ]
          },
          "docs": "Validate a ZIP code and retrieve associated location data including city, county, and state information. Used to validate ZIP code data being submitted to SAM.gov entity registrations and procurement forms."
        }
      ]
    }
  ],
  "bundled": true
}